# Dependencies
backend/vendor/
frontend/node_modules/

# Environment (never commit secrets)
.env
.env.*
!.env.example
!.env.production.example
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production

# Build output (build on deploy — rsync from local/CI, non committare)
frontend/dist/

# Deploy config locale (contiene path SSH personali)
scripts/deploy.config

# Credentials / keys (never commit)
*.pem
*.key
id_rsa
id_ed25519
credentials.json
service-account*.json

# Laravel
backend/storage/*.key
backend/.phpunit.result.cache
backend/bootstrap/cache/*.php
!backend/bootstrap/cache/.gitignore

# IDE / OS
.idea/
.vscode/
.DS_Store
*.log
