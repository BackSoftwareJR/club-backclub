# Club CRM — production template for club.backclub.it
# Copy to .env on the server: cp .env.production.example .env
# Then: php artisan key:generate

APP_NAME="Club CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://club.backclub.it

# Hostinger: leave empty — routes are /entry/... (Apache passes path without /api prefix)
API_ROUTE_PREFIX=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# MySQL (Hostinger hPanel — host is usually localhost)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=club_backclub
DB_USERNAME=club_backclub_user
DB_PASSWORD=your_database_password_here

# Hostinger: database drivers (no Redis/Memcached)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@club.backclub.it"
MAIL_FROM_NAME="${APP_NAME}"

# Hostinger: persistent uploads outside deploy tree (never deleted by rsync)
# MEDIA_ROOT_PATH=/home/u589701076/domains/club.backclub.it/media
# MEDIA_PUBLIC_URL=https://club.backclub.it/api/media

# SPA origin (documentation; CORS is driven by CORS_ALLOWED_ORIGINS)
FRONTEND_URL=https://club.backclub.it

# SPA CORS — must include the production SPA URL
CORS_ALLOWED_ORIGINS=https://club.backclub.it

# JWT — omit JWT_SECRET to use APP_KEY (do not set JWT_SECRET= empty)
JWT_TTL=7200

# Canopywave AI — monthly subscription key (see docs/CANOPYWAVE_SETUP.md)
CANOPYWAVE_ENABLED=true
CANOPYWAVE_BASE_URL=https://inference.canopywave.io/v1
CANOPYWAVE_API_KEY=your_canopywave_subscription_key_here
CANOPYWAVE_MODEL=moonshotai/kimi-k2.6
CANOPYWAVE_TEMPERATURE=0.6
CANOPYWAVE_TIMEOUT=3
CANOPYWAVE_MAX_TOKENS=512
